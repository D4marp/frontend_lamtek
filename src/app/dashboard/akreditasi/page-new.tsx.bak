'use client';

import React, { useState, useEffect } from 'react';
import Link from 'next/link';
import {
  Card,
  Button,
  Input,
  Select,
  Badge,
  Table,
  TableHeader,
  TableBody,
  TableRow,
  TableHead,
  TableCell,
} from '@/components/ui';
import {
  Plus,
  Search,
  Eye,
  Edit,
  Trash2,
  Download,
  Loader2,
  AlertCircle,
  CheckCircle,
  Clock,
  XCircle,
} from 'lucide-react';

interface Akreditasi {
  id: number;
  kodeAkreditasi: string;
  tahun: number;
  tipe: string;
  status: string;
  progress: number;
  institusiId: number;
  prodiId: number;
  uppsId: number;
  jenjangId: number;
  createdAt: string;
}

const STATUS_STAGES = [
  'REGISTRASI',
  'VERIFIKASI_DOKUMEN',
  'PEMBAYARAN',
  'PENAWARAN_ASESOR',
  'ASESMEN_KECUKUPAN',
  'PENGESAHAN_AK',
  'ASESMEN_LAPANGAN',
  'TANGGAPAN_AL',
  'PENGESAHAN_AL',
  'PENETAPAN_PERINGKAT',
  'SINKRONISASI_BANPT',
  'SELESAI',
];

const getStatusVariant = (status: string) => {
  const variants: Record<string, any> = {
    REGISTRASI: 'warning',
    VERIFIKASI_DOKUMEN: 'info',
    PEMBAYARAN: 'warning',
    PENAWARAN_ASESOR: 'info',
    ASESMEN_KECUKUPAN: 'primary',
    PENGESAHAN_AK: 'primary',
    ASESMEN_LAPANGAN: 'warning',
    TANGGAPAN_AL: 'warning',
    PENGESAHAN_AL: 'info',
    PENETAPAN_PERINGKAT: 'success',
    SINKRONISASI_BANPT: 'success',
    SELESAI: 'success',
  };
  return variants[status] || 'secondary';
};

const getStatusIcon = (status: string) => {
  switch (status) {
    case 'SELESAI':
      return <CheckCircle className="w-4 h-4 text-green-600" />;
    case 'REGISTRASI':
      return <Clock className="w-4 h-4 text-yellow-600" />;
    default:
      return <Clock className="w-4 h-4 text-blue-600" />;
  }
};

export default function AkreditasiPage() {
  const [data, setData] = useState<Akreditasi[]>([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [searchQuery, setSearchQuery] = useState('');
  const [filterStatus, setFilterStatus] = useState('');
  const [filterTipe, setFilterTipe] = useState('');

  useEffect(() => {
    fetchData();
  }, []);

  const fetchData = async () => {
    setLoading(true);
    setError(null);
    try {
      // Try the akreditasi endpoint
      const response = await fetch('http://localhost:3003/api/v1/akreditasi', {
        headers: {
          'Authorization': `Bearer ${localStorage.getItem('token') || ''}`,
        },
      });

      if (!response.ok) {
        // Fallback - fetch from direct database query if available
        throw new Error('Failed to fetch akreditasi data');
      }

      const result = await response.json();
      setData(result.data || result || []);
    } catch (err: any) {
      console.error('Error fetching data:', err);
      setError(err.message || 'Gagal memuat data');
      // Display empty state but allow viewing static workflow
      setData([]);
    } finally {
      setLoading(false);
    }
  };

  const filteredData = data.filter((item) => {
    const matchSearch = 
      item.kodeAkreditasi?.toLowerCase().includes(searchQuery.toLowerCase()) ||
      item.tipe?.toLowerCase().includes(searchQuery.toLowerCase());
    const matchStatus = !filterStatus || item.status === filterStatus;
    const matchTipe = !filterTipe || item.tipe === filterTipe;
    return matchSearch && matchStatus && matchTipe;
  });

  const getStageIndex = (status: string) => {
    return STATUS_STAGES.indexOf(status);
  };

  return (
    <div className="space-y-6">
      {/* Header */}
      <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
          <h1 className="text-2xl font-bold text-gray-900">Akreditasi Reguler</h1>
          <p className="text-gray-600 mt-1">Kelola pengajuan akreditasi program studi</p>
        </div>
        <Link href="/dashboard/akreditasi/new" className="w-full sm:w-auto">
          <Button className="w-full sm:w-auto">
            <Plus className="w-4 h-4 mr-2" />
            Pengajuan Baru
          </Button>
        </Link>
      </div>

      {/* Filters */}
      <Card className="p-4">
        <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
          <div className="flex items-center gap-2 md:col-span-2">
            <Search className="w-5 h-5 text-gray-400" />
            <Input
              placeholder="Cari kode akreditasi..."
              value={searchQuery}
              onChange={(e) => setSearchQuery(e.target.value)}
              className="flex-1"
            />
          </div>
          <Select value={filterStatus} onValueChange={setFilterStatus}>
            <option value="">Semua Status</option>
            {STATUS_STAGES.map((status) => (
              <option key={status} value={status}>
                {status}
              </option>
            ))}
          </Select>
          <Select value={filterTipe} onValueChange={setFilterTipe}>
            <option value="">Semua Tipe</option>
            <option value="REGULER">REGULER</option>
            <option value="PJJ">PJJ</option>
            <option value="PRODI_BARU_PTNBH">Prodi Baru PTNBH</option>
            <option value="PRODI_BARU_NON_PTNBH">Prodi Baru Non-PTNBH</option>
          </Select>
        </div>
      </Card>

      {/* Error State */}
      {error && (
        <Card className="p-4 border-red-200 bg-red-50">
          <div className="flex items-center gap-3 text-red-700">
            <AlertCircle className="w-5 h-5" />
            <span>{error}</span>
            <Button
              size="sm"
              variant="ghost"
              onClick={fetchData}
              className="ml-auto text-red-700 hover:text-red-900"
            >
              Coba Lagi
            </Button>
          </div>
        </Card>
      )}

      {/* Loading State */}
      {loading && (
        <div className="flex items-center justify-center h-64">
          <div className="flex flex-col items-center gap-3">
            <Loader2 className="w-8 h-8 animate-spin text-blue-600" />
            <p className="text-gray-600">Memuat data...</p>
          </div>
        </div>
      )}

      {/* Data Table */}
      {!loading && data.length > 0 && (
        <Card>
          <div className="overflow-x-auto">
            <Table>
              <TableHeader>
                <TableRow className="bg-gray-50">
                  <TableHead>Kode Akreditasi</TableHead>
                  <TableHead>Tahun</TableHead>
                  <TableHead>Tipe</TableHead>
                  <TableHead>Status</TableHead>
                  <TableHead>Progress</TableHead>
                  <TableHead>Aksi</TableHead>
                </TableRow>
              </TableHeader>
              <TableBody>
                {filteredData.map((item) => (
                  <TableRow key={item.id} className="hover:bg-gray-50">
                    <TableCell className="font-mono text-sm">{item.kodeAkreditasi}</TableCell>
                    <TableCell>{item.tahun}</TableCell>
                    <TableCell>
                      <Badge variant="outline">{item.tipe}</Badge>
                    </TableCell>
                    <TableCell>
                      <div className="flex items-center gap-2">
                        {getStatusIcon(item.status)}
                        <Badge variant={getStatusVariant(item.status)}>
                          {item.status}
                        </Badge>
                      </div>
                    </TableCell>
                    <TableCell>
                      <div className="flex items-center gap-2">
                        <div className="w-16 bg-gray-200 rounded-full h-2">
                          <div
                            className="bg-blue-600 h-2 rounded-full"
                            style={{ width: `${item.progress}%` }}
                          />
                        </div>
                        <span className="text-sm text-gray-600">{item.progress}%</span>
                      </div>
                    </TableCell>
                    <TableCell>
                      <div className="flex gap-2">
                        <Button
                          size="sm"
                          variant="ghost"
                          asChild
                        >
                          <Link href={`/dashboard/akreditasi/${item.id}`}>
                            <Eye className="w-4 h-4" />
                          </Link>
                        </Button>
                      </div>
                    </TableCell>
                  </TableRow>
                ))}
              </TableBody>
            </Table>
          </div>
        </Card>
      )}

      {/* Workflow Stages Reference */}
      <Card className="p-6">
        <h2 className="text-lg font-semibold mb-4">Tahapan Alur Akreditasi Reguler</h2>
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          {STATUS_STAGES.map((stage, index) => (
            <div key={stage} className="flex items-center gap-3 p-3 rounded-lg bg-gray-50">
              <div className="flex-shrink-0 w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-700 font-semibold text-sm">
                {index + 1}
              </div>
              <div>
                <p className="font-medium text-gray-900">{stage}</p>
                <p className="text-xs text-gray-500">Tahap {index + 1} dari {STATUS_STAGES.length}</p>
              </div>
              {index < STATUS_STAGES.length - 1 && (
                <div className="hidden md:block ml-auto">
                  <div className="flex items-center justify-center w-6 h-6">
                    <div className="border-b-2 border-gray-300 w-6" />
                  </div>
                </div>
              )}
            </div>
          ))}
        </div>
      </Card>

      {/* Empty State */}
      {!loading && data.length === 0 && !error && (
        <Card className="p-12">
          <div className="text-center">
            <AlertCircle className="w-12 h-12 text-gray-400 mx-auto mb-4" />
            <h3 className="text-lg font-semibold text-gray-900 mb-2">Tidak Ada Data</h3>
            <p className="text-gray-600 mb-6">Belum ada pengajuan akreditasi. Mulai dengan mengajukan yang baru.</p>
            <Button asChild>
              <Link href="/dashboard/akreditasi/new">
                <Plus className="w-4 h-4 mr-2" />
                Buat Pengajuan Baru
              </Link>
            </Button>
          </div>
        </Card>
      )}
    </div>
  );
}
